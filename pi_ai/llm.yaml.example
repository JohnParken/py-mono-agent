# LLM 配置文件
# 用于管理多个 LLM 模型配置

# 当前使用的 LLM 配置名称
use_llm: openai_gpt4o

# LLM 配置列表
llms:

  # OpenAI GPT-4o
  openai_gpt4o:
    provider: openai
    api_key: ${OPENAI_API_KEY:}
    base_url: https://api.openai.com/v1
    model: gpt-4o
    description: "OpenAI GPT-4o"

  # OpenAI GPT-4o-mini
  openai_gpt4o_mini:
    provider: openai
    api_key: ${OPENAI_API_KEY:}
    base_url: https://api.openai.com/v1
    model: gpt-4o-mini
    description: "OpenAI GPT-4o-mini"

  # Anthropic Claude Sonnet 4
  claude_sonnet4:
    provider: anthropic
    api_key: ${ANTHROPIC_API_KEY:}
    base_url: https://api.anthropic.com/v1
    model: claude-sonnet-4-20250514
    description: "Anthropic Claude Sonnet 4"

  # Google Gemini
  gemini_pro:
    provider: google
    api_key: ${GOOGLE_API_KEY:}
    base_url: https://generativelanguage.googleapis.com/v1beta
    model: gemini-1.5-pro
    description: "Google Gemini 1.5 Pro"

  # 本地 Ollama
  ollama:
    provider: openai
    api_key: ollama
    base_url: http://localhost:11434/v1
    model: llama3:latest
    description: "本地 Ollama Llama3"

  # DeepSeek
  deepseek:
    provider: openai
    api_key: ${DEEPSEEK_API_KEY:}
    base_url: https://api.deepseek.com/v1
    model: deepseek-chat
    description: "DeepSeek Chat"

  # Qwen 自定义 Provider（requests 实现）
  # 对应请求体中的:
  # - token   <- api_key / DASHSCOPE_API_KEY
  # - apikey  <- 运行时通过 QWEN_APP_API_KEY 或 app_api_key 传入
  # - modelId <- model
  #
  # 可选的 appInfo 字段（如 agent_id / temperature / max_new_tokens）
  # 由调用时的额外参数传入，而不是直接从这份 YAML 读取。
  qwen_compatible:
    provider: QwenLLMprovider
    api_key: ${DASHSCOPE_API_KEY:}
    base_url: https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
    model: lightapplication
    description: "Qwen Custom Streaming Provider"

# 运行 Qwen Provider 前，通常还需要设置：
#
# macOS / Linux:
#   export DASHSCOPE_API_KEY=your-token
#   export QWEN_APP_API_KEY=your-app-api-key
#
# Windows PowerShell:
#   $env:DASHSCOPE_API_KEY="your-token"
#   $env:QWEN_APP_API_KEY="your-app-api-key"
#
# Windows cmd.exe:
#   set DASHSCOPE_API_KEY=your-token
#   set QWEN_APP_API_KEY=your-app-api-key
